{
  "name": "learncode",
  "version": "0.1.0",
  "description": "A Claude Code skill that turns Claude Code into a real-time programming tutor",
  "bin": {
    "learncode": "./dist/cli.js"
  },
  "files": ["dist/", "skill/"],
  "type": "module",
  "scripts": {
    "build": "bun build ./src/cli.ts --outdir ./dist --target node",
    "test": "bun test",
    "dev": "bun run src/cli.ts"
  },
  "dependencies": {
    "cac": "^7.0.0",
    "diff": "^8.0.3"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
